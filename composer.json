{
    "name": "webfiori/collections",
    "description": "Basic collections set used by WebFiori.",
    "type":"library",
    "version":"1.1.4",
    "require": {
        "php": ">=8.1"
    },
    "keywords": [
        "library",
        "webfiori",
        "collection",
        "collections",
        "data structures"
    ],
    "autoload" :{
        "psr-4":{
            "WebFiori\\Collections\\":"WebFiori/Collections/"
        }
    },
    
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "scripts":{
        "test": "vendor/bin/phpunit -c tests/phpunit.xml",
        "test10": "vendor/bin/phpunit -c tests/phpunit10.xml"
    },
    "license": "MIT"
}
